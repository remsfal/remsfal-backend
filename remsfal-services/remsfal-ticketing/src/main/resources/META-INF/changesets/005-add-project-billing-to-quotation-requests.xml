<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                                       http://www.liquibase.org/xml/ns/dbchangelog-ext
                                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="remsfal-ticketing-0.0.5-quotation-requests-project-billing"
               author="alexander.stanik@htw-berlin.de">
        <comment>Add project owner and billing address columns to quotation_requests table</comment>
        <sql>ALTER TABLE REMSFAL.quotation_requests ADD project_owner TEXT;</sql>
        <sql>ALTER TABLE REMSFAL.quotation_requests ADD project_care_of TEXT;</sql>
        <sql>ALTER TABLE REMSFAL.quotation_requests ADD project_billing_address_1 TEXT;</sql>
        <sql>ALTER TABLE REMSFAL.quotation_requests ADD project_billing_address_2 TEXT;</sql>
        <sql>ALTER TABLE REMSFAL.quotation_requests ADD project_billing_address_3 TEXT;</sql>
        <rollback>
            <sql>ALTER TABLE REMSFAL.quotation_requests DROP project_owner;</sql>
            <sql>ALTER TABLE REMSFAL.quotation_requests DROP project_care_of;</sql>
            <sql>ALTER TABLE REMSFAL.quotation_requests DROP project_billing_address_1;</sql>
            <sql>ALTER TABLE REMSFAL.quotation_requests DROP project_billing_address_2;</sql>
            <sql>ALTER TABLE REMSFAL.quotation_requests DROP project_billing_address_3;</sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
