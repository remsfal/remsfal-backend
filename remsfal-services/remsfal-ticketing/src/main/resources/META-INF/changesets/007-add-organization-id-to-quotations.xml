<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                                       http://www.liquibase.org/xml/ns/dbchangelog-ext
                                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="remsfal-ticketing-0.0.7-quotations-organization-id" author="alexander.stanik@htw-berlin.de">
        <comment>Add organization_id column and index to quotations table</comment>
        <sql>
            ALTER TABLE REMSFAL.quotations ADD organization_id UUID;
        </sql>
        <sql>
            CREATE INDEX IF NOT EXISTS quotations_organization_id_idx
            ON REMSFAL.quotations (organization_id);
        </sql>
        <rollback>
            <sql>DROP INDEX IF EXISTS quotations_organization_id_idx;</sql>
            <sql>ALTER TABLE REMSFAL.quotations DROP organization_id;</sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
