<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="remsfal-backend-0.1.9-user-birth-info" author="alexander.stanik@htw-berlin.de">
        <comment>Add optional place of birth and date of birth to users</comment>

        <addColumn tableName="users">
            <column name="place_of_birth" type="varchar(255)" />
            <column name="date_of_birth" type="date" />
        </addColumn>
    </changeSet>

</databaseChangeLog>
